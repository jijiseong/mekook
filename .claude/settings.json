{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-code.sh",
            "timeout": 60,
            "statusMessage": "Formatting & checking..."
          }
        ]
      }
    ]
  }
}
